<!doctype html>
<html lang="zh-CN" data-language="zh" data-accent="safety-orange">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title>Tradar - {{ report.run_summary.run_id }}</title>
  <style>
    :root {
      /* Guizang Social Card / Swiss International / Safety Orange */
      --paper: #fafaf8;
      --ink: #0a0a0a;
      --grey-1: #f0f0ee;
      --grey-2: #d4d4d2;
      --grey-3: #737373;
      --accent: #FF6B35;
      --accent-on: #ffffff;
      --sp-2: 6px;
      --sp-3: 8px;
      --sp-4: 12px;
      --sp-5: 16px;
      --sp-6: 24px;
      --sp-7: 32px;
      --sp-8: 40px;
      --sp-9: 48px;
      --sp-10: 64px;
      --sans: Inter, "Helvetica Neue", Helvetica, "Noto Sans SC", -apple-system, BlinkMacSystemFont, "PingFang SC", "Microsoft YaHei UI", sans-serif;
      --mono: "IBM Plex Mono", "SF Mono", ui-monospace, Menlo, Consolas, monospace;
    }
    *, *::before, *::after { box-sizing: border-box; }
    html { background: var(--paper); }
    body {
      margin: 0;
      color: var(--ink);
      background: var(--paper);
      font-family: var(--sans);
      line-height: 1.5;
      letter-spacing: 0;
      -webkit-font-smoothing: antialiased;
      text-rendering: geometricPrecision;
    }
    a { color: var(--accent); text-decoration-thickness: 1px; text-underline-offset: 4px; }
    a:focus-visible, button:focus-visible, .command:focus-visible {
      outline: 3px solid var(--accent);
      outline-offset: 3px;
    }
    h1, h2, h3, h4, p, ul, ol { margin-top: 0; }
    ul, ol { padding-left: 1.15rem; margin-bottom: 0; }
    li + li { margin-top: var(--sp-2); }
    code, .mono, .t-meta, .command, .command-label, .metric-label, .eyebrow {
      font-family: var(--mono);
    }
    .i18n-en { display: none; }
    html[data-language="en"] .i18n-zh { display: none; }
    html[data-language="en"] .i18n-en { display: inline; }
    .muted { color: var(--grey-3); }
    .guizang-swiss-report {
      width: min(1360px, 100%);
      margin: 0 auto;
      padding: var(--sp-7) var(--sp-6) var(--sp-10);
    }
    .swiss-topbar {
      display: grid;
      grid-template-columns: minmax(0, 1fr) auto;
      gap: var(--sp-6);
      align-items: end;
      border-bottom: 1px solid var(--grey-2);
      padding-bottom: var(--sp-4);
      margin-bottom: var(--sp-5);
    }
    .brand-lockup {
      display: flex;
      gap: var(--sp-4);
      align-items: baseline;
      min-width: 0;
    }
    .brand-mark {
      display: inline-flex;
      align-items: center;
      justify-content: center;
      width: 42px;
      height: 42px;
      background: var(--accent);
      color: var(--accent-on);
      font-weight: 700;
      flex: 0 0 auto;
    }
    .brand-copy strong {
      display: block;
      font-size: 1rem;
      line-height: 1.1;
      font-weight: 600;
      text-transform: uppercase;
    }
    .brand-copy span {
      display: block;
      margin-top: 4px;
      color: var(--grey-3);
      font-size: .82rem;
    }
    .language-switch {
      display: inline-flex;
      border: 1px solid var(--ink);
    }
    .language-switch button {
      min-height: 34px;
      border: 0;
      border-right: 1px solid var(--ink);
      padding: 0 12px;
      background: var(--paper);
      color: var(--ink);
      font: inherit;
      cursor: pointer;
    }
    .language-switch button:last-child { border-right: 0; }
    .language-switch button[aria-pressed="true"] {
      background: var(--ink);
      color: var(--paper);
    }
    .privacy-band {
      display: flex;
      justify-content: space-between;
      gap: var(--sp-5);
      border-bottom: 1px solid var(--grey-2);
      padding: var(--sp-4) 0 var(--sp-5);
      margin-bottom: var(--sp-7);
      color: var(--grey-3);
      font-size: .88rem;
    }
    .report-nav {
      display: grid;
      grid-template-columns: repeat(5, minmax(0, 1fr));
      border: 1px solid var(--ink);
      margin-bottom: var(--sp-7);
    }
    .report-nav a {
      padding: var(--sp-4) var(--sp-5);
      border-right: 1px solid var(--ink);
      color: var(--ink);
      text-decoration: none;
      font-size: .88rem;
      font-weight: 600;
    }
    .report-nav a:last-child { border-right: 0; }
    .report-nav a.primary {
      background: var(--accent);
      color: var(--accent-on);
    }
    .swiss-hero {
      display: grid;
      grid-template-columns: minmax(0, 1.05fr) minmax(360px, .95fr);
      gap: var(--sp-7);
      margin-bottom: var(--sp-10);
    }
    .hero-statement, .weekly-module {
      border-top: 6px solid var(--accent);
      border-bottom: 1px solid var(--grey-2);
      padding: var(--sp-7) 0 var(--sp-6);
      min-width: 0;
    }
    .eyebrow {
      margin-bottom: var(--sp-5);
      color: var(--accent);
      font-size: .76rem;
      font-weight: 600;
      letter-spacing: .08em;
      text-transform: uppercase;
    }
    h1 {
      margin-bottom: var(--sp-6);
      font-size: clamp(4.8rem, 10vw, 8.6rem);
      line-height: .96;
      font-weight: 200;
      letter-spacing: 0;
    }
    h2 {
      margin-bottom: var(--sp-4);
      font-size: clamp(2.1rem, 4vw, 4rem);
      line-height: 1.02;
      font-weight: 300;
      letter-spacing: 0;
    }
    h3 {
      margin-bottom: var(--sp-3);
      font-size: 1.22rem;
      line-height: 1.2;
      font-weight: 500;
      letter-spacing: 0;
    }
    h4 {
      margin: var(--sp-5) 0 var(--sp-3);
      color: var(--grey-3);
      font-family: var(--mono);
      font-size: .74rem;
      font-weight: 600;
      letter-spacing: .08em;
      text-transform: uppercase;
    }
    .hero-lead {
      max-width: 780px;
      margin-bottom: var(--sp-6);
      font-size: 1.16rem;
      line-height: 1.65;
    }
    .confidence-note {
      display: grid;
      grid-template-columns: 120px minmax(0, 1fr);
      gap: var(--sp-5);
      border-top: 1px solid var(--grey-2);
      padding-top: var(--sp-5);
      color: var(--grey-3);
    }
    .hero-metrics {
      grid-column: 1 / -1;
      display: grid;
      grid-template-columns: repeat(8, minmax(0, 1fr));
      border-top: 1px solid var(--ink);
      border-bottom: 1px solid var(--ink);
    }
    .hero-metrics .metric-tile { grid-column: span 1; }
    .hero-metrics .metric-tile.metric-wide { grid-column: span 2; }
    .metric-tile {
      min-width: 0;
      padding: var(--sp-5);
      border-right: 1px solid var(--grey-2);
      background: var(--paper);
    }
    .metric-tile:last-child { border-right: 0; }
    .metric-label {
      display: block;
      color: var(--grey-3);
      font-size: .72rem;
      letter-spacing: .08em;
      text-transform: uppercase;
    }
    .metric-tile strong {
      display: block;
      margin-top: var(--sp-3);
      overflow-wrap: anywhere;
      font-size: 1rem;
      line-height: 1.35;
      font-weight: 500;
    }
    .weekly-module {
      display: grid;
      align-content: start;
      gap: var(--sp-5);
      background: var(--grey-1);
      padding: var(--sp-7);
    }
    .status-line {
      display: flex;
      flex-wrap: wrap;
      gap: var(--sp-3);
      align-items: center;
      color: var(--grey-3);
    }
    .pill {
      display: inline-flex;
      align-items: center;
      min-height: 26px;
      border: 1px solid var(--grey-2);
      padding: 2px 8px;
      background: var(--paper);
      color: var(--grey-3);
      font-family: var(--mono);
      font-size: .72rem;
      overflow-wrap: anywhere;
    }
    .pill-accent {
      border-color: var(--accent);
      background: var(--accent);
      color: var(--accent-on);
    }
    .swiss-section {
      border-top: 1px solid var(--ink);
      padding-top: var(--sp-6);
      margin-bottom: var(--sp-10);
    }
    .section-heading {
      display: grid;
      grid-template-columns: minmax(0, 1fr) auto;
      gap: var(--sp-6);
      align-items: end;
      margin-bottom: var(--sp-7);
    }
    .section-heading h2 { margin-bottom: 0; }
    .panel-grid-3 {
      display: grid;
      grid-template-columns: repeat(3, minmax(0, 1fr));
      border-top: 1px solid var(--grey-2);
      border-left: 1px solid var(--grey-2);
    }
    .panel-grid-2 {
      display: grid;
      grid-template-columns: repeat(2, minmax(0, 1fr));
      border-top: 1px solid var(--grey-2);
      border-left: 1px solid var(--grey-2);
    }
    .swiss-panel, .matrix-cell, .state-cell {
      min-width: 0;
      padding: var(--sp-6);
      border-right: 1px solid var(--grey-2);
      border-bottom: 1px solid var(--grey-2);
      background: var(--paper);
    }
    .swiss-panel.alt, .matrix-cell.alt, .state-cell.alt { background: var(--grey-1); }
    .swiss-panel.accent, .matrix-cell.accent {
      background: var(--accent);
      color: var(--accent-on);
    }
    .swiss-panel.accent h3, .swiss-panel.accent h4, .swiss-panel.accent p,
    .matrix-cell.accent h4, .matrix-cell.accent p, .matrix-cell.accent li {
      color: var(--accent-on);
    }
    .technical-appendix {
      border-top: 1px solid var(--ink);
      margin-bottom: var(--sp-10);
    }
    .technical-appendix summary {
      display: flex;
      justify-content: space-between;
      gap: var(--sp-6);
      padding: var(--sp-5) 0;
      color: var(--grey-3);
      cursor: pointer;
      list-style: none;
    }
    .technical-appendix summary::-webkit-details-marker { display: none; }
    .technical-appendix summary strong {
      color: var(--ink);
      font-size: 1rem;
    }
    .source-metrics {
      display: grid;
      grid-template-columns: repeat(3, minmax(0, 1fr));
      gap: 0;
      border-top: 1px solid var(--grey-2);
      border-left: 1px solid var(--grey-2);
      margin-top: var(--sp-6);
    }
    .source-metrics .metric-tile {
      border-bottom: 1px solid var(--grey-2);
      background: var(--grey-1);
    }
    .artifact-list {
      columns: 2;
      column-gap: var(--sp-8);
    }
    .opportunity-ledger {
      display: grid;
      grid-template-columns: 184px minmax(0, 1fr);
      gap: var(--sp-7);
      border-top: 1px solid var(--grey-2);
      padding: var(--sp-7) 0;
    }
    .opportunity-ledger:last-child { border-bottom: 1px solid var(--grey-2); }
    .recommended-project {
      border-top: 1px solid var(--grey-2);
      margin-bottom: var(--sp-8);
    }
    .candidate-heading {
      display: flex;
      justify-content: space-between;
      gap: var(--sp-5);
      align-items: end;
      border-top: 1px solid var(--ink);
      padding-top: var(--sp-6);
      margin: var(--sp-9) 0 0;
    }
    .ledger-index {
      display: flex;
      flex-direction: column;
      gap: var(--sp-4);
      min-width: 0;
    }
    .ledger-index .number {
      display: block;
      color: var(--accent);
      font-size: clamp(3rem, 6vw, 5.4rem);
      line-height: .9;
      font-weight: 200;
    }
    .ledger-main {
      display: grid;
      grid-template-columns: minmax(0, .9fr) minmax(0, 1.1fr);
      gap: var(--sp-7);
      min-width: 0;
    }
    .opportunity-title { margin-bottom: var(--sp-4); }
    .evidence-list li::marker { color: var(--accent); }
    .swiss-matrix {
      display: grid;
      grid-template-columns: repeat(2, minmax(0, 1fr));
      border-top: 1px solid var(--grey-2);
      border-left: 1px solid var(--grey-2);
    }
    .demo-atelier-item {
      border-top: 1px solid var(--grey-2);
      padding-top: var(--sp-7);
      margin-bottom: var(--sp-9);
    }
    .brief-grid {
      display: grid;
      grid-template-columns: repeat(2, minmax(0, 1fr));
      gap: var(--sp-7);
      margin-bottom: var(--sp-7);
    }
    .product-frame {
      display: grid;
      grid-template-columns: minmax(0, 1.2fr) minmax(300px, .8fr);
      gap: var(--sp-7);
      align-items: stretch;
    }
    .product-ui-screen {
      display: grid;
      grid-template-columns: 160px minmax(0, 1fr);
      min-height: 520px;
      border: 1px solid var(--ink);
      background: var(--paper);
    }
    .product-ui-rail {
      display: grid;
      grid-template-rows: auto 1fr auto;
      gap: var(--sp-6);
      padding: var(--sp-6);
      background: var(--ink);
      color: var(--paper);
    }
    .product-ui-logo {
      display: inline-flex;
      align-items: center;
      justify-content: center;
      width: 42px;
      height: 42px;
      background: var(--accent);
      color: var(--accent-on);
      font-weight: 700;
    }
    .product-ui-nav {
      display: grid;
      gap: var(--sp-3);
      align-content: start;
    }
    .product-ui-nav span {
      display: block;
      border-left: 3px solid transparent;
      padding: var(--sp-3) 0 var(--sp-3) var(--sp-4);
      color: var(--grey-2);
      font-size: .82rem;
    }
    .product-ui-nav span.active {
      border-left-color: var(--accent);
      color: var(--paper);
    }
    .product-ui-main {
      display: grid;
      grid-template-rows: auto minmax(0, 1fr);
      min-width: 0;
    }
    .product-ui-toolbar {
      display: flex;
      justify-content: space-between;
      gap: var(--sp-5);
      align-items: start;
      padding: var(--sp-6);
      border-bottom: 1px solid var(--grey-2);
    }
    .product-ui-action {
      flex: 0 0 auto;
      background: var(--accent);
      color: var(--accent-on);
      padding: var(--sp-3) var(--sp-5);
      font-size: .84rem;
      font-weight: 700;
      white-space: nowrap;
    }
    .product-ui-workspace {
      display: grid;
      grid-template-columns: minmax(0, 1fr) 260px;
      gap: 0;
      min-width: 0;
    }
    .product-ui-list {
      display: grid;
      align-content: start;
      border-right: 1px solid var(--grey-2);
      min-width: 0;
    }
    .product-row {
      display: grid;
      grid-template-columns: minmax(0, 1fr) auto;
      gap: var(--sp-5);
      align-items: center;
      padding: var(--sp-5) var(--sp-6);
      border-bottom: 1px solid var(--grey-2);
      min-width: 0;
    }
    .product-row strong, .product-row span { overflow-wrap: anywhere; }
    .product-chip {
      border: 1px solid var(--accent);
      color: var(--accent);
      padding: 2px 8px;
      font-family: var(--mono);
      font-size: .72rem;
      white-space: nowrap;
    }
    .product-ui-inspector {
      display: grid;
      align-content: start;
      gap: var(--sp-5);
      padding: var(--sp-6);
      background: var(--grey-1);
      min-width: 0;
    }
    .product-data-list {
      display: grid;
      gap: var(--sp-3);
      margin: 0;
      padding: 0;
      list-style: none;
    }
    .product-data-list li {
      border-bottom: 1px solid var(--grey-2);
      padding-bottom: var(--sp-3);
      overflow-wrap: anywhere;
    }
    .state-grid, .path-grid {
      display: grid;
      grid-template-columns: repeat(2, minmax(0, 1fr));
      border-top: 1px solid var(--grey-2);
      border-left: 1px solid var(--grey-2);
      margin-top: var(--sp-5);
    }
    .path-grid {
      grid-template-columns: repeat(3, minmax(0, 1fr));
      margin-top: var(--sp-6);
    }
    .command-stack {
      display: grid;
      gap: var(--sp-4);
    }
    .command-row {
      display: grid;
      grid-template-columns: 112px minmax(0, 1fr);
      align-items: stretch;
      border: 1px solid var(--ink);
    }
    .command-label {
      display: flex;
      align-items: center;
      padding: var(--sp-4);
      background: var(--ink);
      color: var(--paper);
      font-size: .72rem;
      font-weight: 600;
      letter-spacing: .08em;
      text-transform: uppercase;
    }
    .command {
      min-width: 0;
      padding: var(--sp-4);
      background: var(--paper);
      color: var(--ink);
      overflow-wrap: anywhere;
      white-space: normal;
    }
    .decision-grid {
      display: grid;
      grid-template-columns: minmax(0, 1fr) minmax(0, 1fr);
      gap: var(--sp-7);
      margin-top: var(--sp-7);
    }
    .action-copy {
      max-width: 760px;
      margin-bottom: var(--sp-6);
      color: var(--grey-3);
      font-size: 1.05rem;
    }
    @media (max-width: 980px) {
      .guizang-swiss-report { padding: var(--sp-5) var(--sp-5) var(--sp-8); }
      .swiss-topbar, .privacy-band, .swiss-hero, .section-heading,
      .ledger-main, .brief-grid, .product-frame, .decision-grid {
        grid-template-columns: 1fr;
      }
      .report-nav { grid-template-columns: 1fr; }
      .report-nav a { border-right: 0; border-bottom: 1px solid var(--ink); }
      .report-nav a:last-child { border-bottom: 0; }
      .privacy-band { display: grid; }
      .hero-metrics, .panel-grid-3, .panel-grid-2, .source-metrics,
      .swiss-matrix, .state-grid, .path-grid {
        grid-template-columns: 1fr;
      }
      .metric-tile, .swiss-panel, .matrix-cell, .state-cell {
        border-right: 1px solid var(--grey-2);
      }
      .hero-metrics .metric-tile,
      .hero-metrics .metric-tile.metric-wide {
        grid-column: auto;
      }
      .opportunity-ledger { grid-template-columns: 1fr; }
      .product-ui-screen { grid-template-columns: 1fr; }
      .product-ui-rail { display: none; }
      .product-ui-workspace { grid-template-columns: 1fr; }
      .product-ui-list { border-right: 0; }
      .command-row { grid-template-columns: 1fr; }
      .artifact-list { columns: 1; }
      h1 { font-size: clamp(3.5rem, 18vw, 6rem); }
    }
  </style>
</head>
<body>
<main class="guizang-swiss-report">
  <nav class="swiss-topbar" aria-label="Language">
    <div class="brand-lockup">
      <span class="brand-mark">T</span>
      <span class="brand-copy">
        <strong>Tradar / Local Agent Opportunity Radar</strong>
        <span>rendered_by: {{ report.run_summary.rendered_by }}</span>
      </span>
    </div>
    <div class="language-switch">
      <button type="button" data-language-button="zh" aria-pressed="true">中文</button>
      <button type="button" data-language-button="en" aria-pressed="false">English</button>
    </div>
  </nav>

  <p class="privacy-band">
    <span><span class="i18n-zh">本报告基于本地数据生成，未做完整脱敏。</span><span class="i18n-en">This report is generated from local data and is not fully redacted.</span></span>
    <span class="t-meta">Safety Orange / Swiss International</span>
  </p>

  <nav class="report-nav" aria-label="Report sections">
    <a class="primary" href="#recommended-project"><span class="i18n-zh">首选项目</span><span class="i18n-en">Recommended</span></a>
    <a href="#candidate-projects"><span class="i18n-zh">待考察项目</span><span class="i18n-en">Candidates</span></a>
    <a href="#demo-briefs"><span class="i18n-zh">Demo 简报</span><span class="i18n-en">Demo Briefs</span></a>
    <a href="#next-action"><span class="i18n-zh">下一步</span><span class="i18n-en">Next Action</span></a>
    <a href="#technical-appendix"><span class="i18n-zh">技术附录</span><span class="i18n-en">Technical</span></a>
  </nav>

  <header class="swiss-hero" aria-labelledby="run-summary">
    <div class="hero-statement">
      <p class="eyebrow">Tradar Decision Radar</p>
      <h1 id="run-summary"><span class="i18n-zh">运行摘要</span><span class="i18n-en">Run Summary</span></h1>
      {% if report.this_weeks_demo %}
        <p class="hero-lead">{{ report.this_weeks_demo.summary }}</p>
      {% else %}
        <p class="hero-lead"><span class="i18n-zh">本周不建议启动 demo。先补充 evidence 或运行 sources doctor。</span><span class="i18n-en">No demo is recommended this week. Add evidence or run sources doctor first.</span></p>
      {% endif %}
      {% if report.run_summary.confidence_note %}
        <div class="confidence-note">
          <span class="metric-label"><span class="i18n-zh">置信度</span><span class="i18n-en">Confidence</span></span>
          <span>{{ report.run_summary.confidence_note }}</span>
        </div>
      {% endif %}
    </div>

    <aside class="weekly-module" aria-labelledby="this-weeks-demo">
      <p class="eyebrow"><span class="i18n-zh">本周 Demo</span><span class="i18n-en">This Week's Demo</span></p>
      {% if report.this_weeks_demo %}
        <h2 id="this-weeks-demo">{{ report.this_weeks_demo.title }}</h2>
        <p>{{ report.this_weeks_demo.summary }}</p>
        <div class="status-line">
          <span class="pill pill-accent"><span class="i18n-zh">首选实施</span><span class="i18n-en">recommended</span></span>
          <span class="pill">evidence_strength: {{ report.this_weeks_demo.evidence_strength }}</span>
        </div>
        <div class="command-stack">
          <div class="command-row">
            <span class="command-label">start</span>
            <div class="command" tabindex="0">{{ report.this_weeks_demo.start_command }}</div>
          </div>
          <div class="command-row">
            <span class="command-label">skip</span>
            <div class="command" tabindex="0">{{ report.this_weeks_demo.skip_command }}</div>
          </div>
        </div>
      {% else %}
        <h2 id="this-weeks-demo"><span class="i18n-zh">本周 Demo</span><span class="i18n-en">This Week's Demo</span></h2>
        <p><span class="i18n-zh">本周不建议启动 demo。先补充 evidence 或运行 sources doctor。</span><span class="i18n-en">No demo is recommended this week. Add evidence or run sources doctor first.</span></p>
      {% endif %}
    </aside>

    <div class="hero-metrics" aria-label="run metrics">
      <div class="metric-tile metric-wide"><span class="metric-label"><span class="i18n-zh">本周建议</span><span class="i18n-en">weekly choice</span></span><strong>{% if report.this_weeks_demo %}<span class="i18n-zh">启动首选项目</span><span class="i18n-en">start recommended project</span>{% else %}<span class="i18n-zh">暂不启动</span><span class="i18n-en">do not start yet</span>{% endif %}</strong></div>
      <div class="metric-tile metric-wide"><span class="metric-label"><span class="i18n-zh">候选项目</span><span class="i18n-en">candidate projects</span></span><strong>{{ report.opportunity_cards | length }}</strong></div>
      <div class="metric-tile"><span class="metric-label"><span class="i18n-zh">窗口天数</span><span class="i18n-en">days_window</span></span><strong>{{ report.run_summary.days_window }}</strong></div>
      <div class="metric-tile"><span class="metric-label"><span class="i18n-zh">证据数量</span><span class="i18n-en">evidence_count</span></span><strong>{{ report.run_summary.evidence_count }}</strong></div>
      <div class="metric-tile"><span class="metric-label"><span class="i18n-zh">告警数量</span><span class="i18n-en">warning_count</span></span><strong>{{ report.run_summary.warning_count }}</strong></div>
      <div class="metric-tile"><span class="metric-label"><span class="i18n-zh">报告状态</span><span class="i18n-en">Report Status</span></span><strong>{{ report.run_summary.report_status }}</strong></div>
    </div>
  </header>

  <details class="technical-appendix" id="technical-appendix">
    <summary>
      <strong><span class="i18n-zh">技术附录</span><span class="i18n-en">Technical Appendix</span></strong>
      <span><span class="i18n-zh">数据源、Agent 运行和调试产物默认收起。</span><span class="i18n-en">Sources, agent runtime, and debug artifacts are collapsed by default.</span></span>
    </summary>
  <section class="swiss-section source-ledger" aria-label="run diagnostics">
    <div class="section-heading">
      <div>
        <p class="eyebrow"><span class="i18n-zh">诊断</span><span class="i18n-en">Diagnostics</span></p>
        <h2><span class="i18n-zh">数据源、Agent 轨迹、产物</span><span class="i18n-en">Sources, Agent Trace, Artifacts</span></h2>
      </div>
      <span class="pill">timezone: {{ report.run_summary.timezone }}</span>
    </div>

    <div class="panel-grid-3">
      <div class="swiss-panel">
        <h3><span class="i18n-zh">数据源</span><span class="i18n-en">Sources</span></h3>
        <h4><span class="i18n-zh">已请求</span><span class="i18n-en">requested</span></h4>
        <p class="mono">{{ report.run_summary.sources_requested | join(", ") }}</p>
        <h4><span class="i18n-zh">成功</span><span class="i18n-en">succeeded</span></h4>
        <p class="mono">{{ report.run_summary.sources_succeeded | join(", ") }}</p>
        <h4><span class="i18n-zh">失败</span><span class="i18n-en">failed</span></h4>
        <p class="mono">{{ report.run_summary.sources_failed | join(", ") }}</p>
      </div>
      <div class="swiss-panel alt">
        <h3><span class="i18n-zh">告警</span><span class="i18n-en">Warnings</span></h3>
        {% if report.run_summary.status_notes %}
          <ul>{% for note in report.run_summary.status_notes %}<li>{{ note }}</li>{% endfor %}</ul>
        {% else %}
          <p class="muted"><span class="i18n-zh">没有状态备注。</span><span class="i18n-en">No status notes.</span></p>
        {% endif %}
        {% if report.run_summary.warning_events %}
          <h4><span class="i18n-zh">告警事件</span><span class="i18n-en">Warning Events</span></h4>
          <ul>{% for key, value in report.run_summary.warning_events.items() %}<li><span class="mono">{{ key }}</span>: <span class="mono">{{ value }}</span></li>{% endfor %}</ul>
        {% endif %}
        {% if report.run_summary.source_warning_counts %}
          <h4><span class="i18n-zh">数据源告警计数</span><span class="i18n-en">Source Warning Counts</span></h4>
          <ul>{% for key, value in report.run_summary.source_warning_counts.items() %}<li><span class="mono">{{ key }}</span>: <span class="mono">{{ value }}</span></li>{% endfor %}</ul>
        {% endif %}
      </div>
      <div class="swiss-panel">
        <h3><span class="i18n-zh">Agent 轨迹</span><span class="i18n-en">Agent Trace</span></h3>
        {% if report.run_summary.agent_elapsed_ms is not none %}
          <ul>
            <li><span class="i18n-zh">Agent 耗时约</span><span class="i18n-en">Agent runtime about</span>: <span class="mono">{{ (report.run_summary.agent_elapsed_ms / 1000) | round(1) }}s</span></li>
            <li>search_used_count: <span class="mono">{{ report.run_summary.search_used_count }}</span></li>
            <li>repair_used: <span class="mono">{{ report.run_summary.repair_used }}</span></li>
            {% if report.run_summary.repair_elapsed_ms is not none %}<li>repair_elapsed_ms: <span class="mono">{{ report.run_summary.repair_elapsed_ms }}</span></li>{% endif %}
            {% if report.run_summary.enhanced_elapsed_ms is not none %}<li>enhanced_elapsed_ms: <span class="mono">{{ report.run_summary.enhanced_elapsed_ms }}</span></li>{% endif %}
          </ul>
          {% if report.run_summary.search_trace_summary %}<p>{{ report.run_summary.search_trace_summary }}</p>{% endif %}
        {% else %}
          <p class="muted"><span class="i18n-zh">Base 报告路径没有调用分析 Agent。</span><span class="i18n-en">The base report path did not call an analyst agent.</span></p>
        {% endif %}
      </div>
    </div>

    {% if report.run_summary.source_scan_file_counts %}
      <h3><span class="i18n-zh">数据源扫描指标</span><span class="i18n-en">Source Scan Metrics</span></h3>
      <div class="source-metrics">
        {% for key, value in report.run_summary.source_scan_file_counts.items() %}
          <div class="metric-tile">
            <span class="metric-label">{{ key }}</span>
            <strong>{{ value }} files / {{ report.run_summary.source_scan_elapsed_ms.get(key, 0) }} ms</strong>
          </div>
        {% endfor %}
      </div>
    {% endif %}
    {% if report.run_summary.next_steps %}
      <div class="swiss-panel alt">
        <h3><span class="i18n-zh">下一步</span><span class="i18n-en">Next Steps</span></h3>
        <ul>{% for step in report.run_summary.next_steps %}<li><span class="mono">{{ step }}</span></li>{% endfor %}</ul>
      </div>
    {% endif %}
    {% if report.run_summary.config_overrides %}
      <div class="swiss-panel">
        <h3><span class="i18n-zh">提示词资产</span><span class="i18n-en">Prompt Assets</span></h3>
        <ul>{% for key, value in report.run_summary.config_overrides.items() %}<li><span class="mono">{{ key }}</span>: <span class="mono">{{ value }}</span></li>{% endfor %}</ul>
      </div>
    {% endif %}
    {% if report.run_summary.debug_bundle_path %}
      <div class="swiss-panel alt">
        <h3><span class="i18n-zh">调试产物</span><span class="i18n-en">Debug Artifacts</span></h3>
        <p class="muted"><span class="i18n-zh">本地运行目录</span><span class="i18n-en">local run directory</span>: <span class="mono">{{ report.run_summary.debug_bundle_path }}</span></p>
        <ul class="artifact-list">
          {% for artifact in ["run.json", "warnings.jsonl", "evidence_pack.json", "agent_raw_output.json", "validated_report.json", "render.log", "report.html"] %}
            <li><a class="mono" href="{{ artifact }}">{{ artifact }}</a></li>
          {% endfor %}
        </ul>
      </div>
    {% endif %}
  </section>
  </details>

  <section class="swiss-section opportunity-section" aria-labelledby="project-opportunity-cards">
    <div class="section-heading">
      <div>
        <p class="eyebrow"><span class="i18n-zh">证据支撑的选项</span><span class="i18n-en">Evidence-backed options</span></p>
        <h2 id="project-opportunity-cards"><span class="i18n-zh">项目机会卡</span><span class="i18n-en">Project Opportunity Cards</span></h2>
      </div>
      <span class="pill">{{ report.opportunity_cards | length }} cards</span>
    </div>
    {% set recommended_card_id = report.this_weeks_demo.card_id if report.this_weeks_demo else report.decision_prompt.suggested_start_card_id %}
    <div class="recommended-project" id="recommended-project">
    {% for card in report.opportunity_cards if card.card_id == recommended_card_id %}
      <article class="opportunity-ledger">
        <div class="ledger-index">
          <span class="number">01</span>
          <span class="pill pill-accent"><span class="i18n-zh">首选实施</span><span class="i18n-en">recommended</span></span>
          <span class="pill"><span class="i18n-zh">本周只做这一个</span><span class="i18n-en">one focus this week</span></span>
        </div>
        <div class="ledger-main">
          <div>
            <h3 class="opportunity-title">{{ card.title }}</h3>
            <p>{{ card.one_sentence }}</p>
            <h4><span class="i18n-zh">证据</span><span class="i18n-en">Evidence</span></h4>
            <ul class="evidence-list">{% for note in card.evidence_notes %}<li>{{ note }}</li>{% endfor %}</ul>
          </div>
          <div class="swiss-matrix">
            <div class="matrix-cell alt">
              <h4><span class="i18n-zh">为什么是你</span><span class="i18n-en">Why You</span></h4>
              <ul>{% for item in card.why_you %}<li>{{ item }}</li>{% endfor %}</ul>
            </div>
            <div class="matrix-cell">
              <h4><span class="i18n-zh">为什么是现在</span><span class="i18n-en">Why Now</span></h4>
              <ul>{% for item in card.why_now %}<li>{{ item }}</li>{% endfor %}</ul>
            </div>
            <div class="matrix-cell">
              <h4><span class="i18n-zh">首批用户</span><span class="i18n-en">First Users</span></h4>
              <p>{{ card.first_users }}</p>
              <h4><span class="i18n-zh">48 小时 Demo</span><span class="i18n-en">48h Demo</span></h4>
              <ul>{% for item in card.demo_48h %}<li>{{ item }}</li>{% endfor %}</ul>
            </div>
            <div class="matrix-cell alt">
              <h4><span class="i18n-zh">风险</span><span class="i18n-en">Risks</span></h4>
              <ul>{% for item in card.risks %}<li>{{ item }}</li>{% endfor %}</ul>
              <h4><span class="i18n-zh">终止信号</span><span class="i18n-en">Kill Signal</span></h4>
              <ul>{% for item in card.kill_signals %}<li>{{ item }}</li>{% endfor %}</ul>
            </div>
          </div>
        </div>
      </article>
    {% else %}
      <p><span class="i18n-zh">当前没有足够 evidence 选出首选项目。</span><span class="i18n-en">There is not enough evidence to choose one recommended project.</span></p>
    {% endfor %}
    </div>

    <div class="candidate-heading" id="candidate-projects">
      <div>
        <p class="eyebrow"><span class="i18n-zh">待考察项目</span><span class="i18n-en">Candidates</span></p>
        <h3><span class="i18n-zh">不是本周主线，先保留观察</span><span class="i18n-en">Not this week's main line; keep watching</span></h3>
      </div>
      <span class="pill"><span class="i18n-zh">避免信息过载</span><span class="i18n-en">avoid overload</span></span>
    </div>
    {% for card in report.opportunity_cards if card.card_id != recommended_card_id %}
      <article class="opportunity-ledger">
        <div class="ledger-index">
          <span class="number">{{ "%02d"|format(loop.index + 1) }}</span>
          <span class="pill"><span class="i18n-zh">待考察</span><span class="i18n-en">candidate</span></span>
          <span class="pill">search: {{ card.search_trace.impact }}</span>
        </div>
        <div class="ledger-main">
          <div>
            <h3 class="opportunity-title">{{ card.title }}</h3>
            <p>{{ card.one_sentence }}</p>
            <h4><span class="i18n-zh">证据</span><span class="i18n-en">Evidence</span></h4>
            <ul class="evidence-list">{% for note in card.evidence_notes %}<li>{{ note }}</li>{% endfor %}</ul>
          </div>
          <div class="swiss-matrix">
            <div class="matrix-cell alt">
              <h4><span class="i18n-zh">为什么是你</span><span class="i18n-en">Why You</span></h4>
              <ul>{% for item in card.why_you %}<li>{{ item }}</li>{% endfor %}</ul>
            </div>
            <div class="matrix-cell">
              <h4><span class="i18n-zh">为什么是现在</span><span class="i18n-en">Why Now</span></h4>
              <ul>{% for item in card.why_now %}<li>{{ item }}</li>{% endfor %}</ul>
            </div>
            <div class="matrix-cell">
              <h4><span class="i18n-zh">首批用户</span><span class="i18n-en">First Users</span></h4>
              <p>{{ card.first_users }}</p>
              <h4><span class="i18n-zh">48 小时 Demo</span><span class="i18n-en">48h Demo</span></h4>
              <ul>{% for item in card.demo_48h %}<li>{{ item }}</li>{% endfor %}</ul>
            </div>
            <div class="matrix-cell alt">
              <h4><span class="i18n-zh">风险</span><span class="i18n-en">Risks</span></h4>
              <ul>{% for item in card.risks %}<li>{{ item }}</li>{% endfor %}</ul>
              <h4><span class="i18n-zh">终止信号</span><span class="i18n-en">Kill Signal</span></h4>
              <ul>{% for item in card.kill_signals %}<li>{{ item }}</li>{% endfor %}</ul>
            </div>
          </div>
        </div>
      </article>
    {% endfor %}
  </section>

  <section class="swiss-section demo-atelier" aria-labelledby="demo-briefs">
