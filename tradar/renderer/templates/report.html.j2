              <div class="product-ui-logo">T</div>
              <div class="product-ui-nav">
                <span class="active"><span class="i18n-zh">机会</span><span class="i18n-en">Opportunities</span></span>
                <span><span class="i18n-zh">证据</span><span class="i18n-en">Evidence</span></span>
                <span><span class="i18n-zh">决策</span><span class="i18n-en">Decision</span></span>
              </div>
              <span class="t-meta">48H / LOCAL</span>
            </aside>
            <div class="product-ui-main">
              <div class="product-ui-toolbar">
                <div>
                  <span class="metric-label"><span class="i18n-zh">高保真画面</span><span class="i18n-en">Hi-Fi screen</span></span>
                  <h3>{{ card.title }}</h3>
                </div>
                <div class="product-ui-action"><span class="i18n-zh">启动 Demo</span><span class="i18n-en">Start demo</span></div>
              </div>
              <div class="product-ui-workspace">
                <div class="product-ui-list">
                  <div class="product-row"><strong>{{ card.demo_brief.prototype_panel.one_screen_mock }}</strong><span class="product-chip">{{ card.status_hint }}</span></div>
                  <div class="product-row"><span>{{ card.demo_brief.prototype_panel.core_interaction_state }}</span><span class="product-chip">{{ card.evidence_ids | length }} ev</span></div>
                  <div class="product-row"><span>{{ card.demo_brief.core_interaction }}</span><span class="product-chip">48h</span></div>
                  <div class="product-row"><span>{{ card.demo_brief.demo_success_signal }}</span><span class="product-chip">signal</span></div>
                </div>
