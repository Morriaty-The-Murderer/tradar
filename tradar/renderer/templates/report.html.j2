                  <div>
                    <span class="metric-label"><span class="i18n-zh">界面数据</span><span class="i18n-en">UI data</span></span>
                    <ul class="product-data-list">{% for item in card.demo_brief.prototype_panel.data_placeholders %}<li><span class="mono">{{ item }}</span></li>{% endfor %}</ul>
                  </div>
                  <div>
                    <span class="metric-label"><span class="i18n-zh">画面目标</span><span class="i18n-en">Screen goal</span></span>
                    <p>{{ card.demo_brief.demo_success_signal }}</p>
                  </div>
                </aside>
              </div>
            </div>
          </div>
          <div>
            <h4><span class="i18n-zh">核心交互状态</span><span class="i18n-en">Core interaction state</span></h4>
            <p>{{ card.demo_brief.prototype_panel.core_interaction_state }}</p>
            <div class="state-grid">
              <div class="state-cell alt">
                <span class="metric-label"><span class="i18n-zh">空状态</span><span class="i18n-en">empty state</span></span>
                <p>{{ card.demo_brief.prototype_panel.empty_state }}</p>
              </div>
              <div class="state-cell">
                <span class="metric-label"><span class="i18n-zh">成功状态</span><span class="i18n-en">success state</span></span>
                <p>{{ card.demo_brief.prototype_panel.success_state }}</p>
              </div>
            </div>
            <h4><span class="i18n-zh">高保真生成提示</span><span class="i18n-en">Hi-fi generation prompt</span></h4>
            <p>{{ card.demo_brief.prototype_prompt }}</p>
          </div>
        </div>

        {% if card.credible_success_path %}
          <h4><span class="i18n-zh">产品可信成功路径</span><span class="i18n-en">Product Credible Success Path</span></h4>
          <div class="path-grid">
            <div class="state-cell alt"><span class="metric-label"><span class="i18n-zh">窄用户</span><span class="i18n-en">narrow user</span></span><strong>{{ card.credible_success_path.narrow_user }}</strong></div>
            <div class="state-cell"><span class="metric-label"><span class="i18n-zh">当前替代品</span><span class="i18n-en">alternative</span></span><strong>{{ card.credible_success_path.current_alternative }}</strong></div>
            <div class="state-cell alt"><span class="metric-label"><span class="i18n-zh">需求证据</span><span class="i18n-en">demand evidence</span></span><strong>{{ card.credible_success_path.credible_demand_evidence }}</strong></div>
            <div class="state-cell"><span class="metric-label"><span class="i18n-zh">分发路径</span><span class="i18n-en">distribution</span></span><strong>{{ card.credible_success_path.first_distribution_path }}</strong></div>
            <div class="state-cell alt"><span class="metric-label"><span class="i18n-zh">两周信号</span><span class="i18n-en">two week signal</span></span><strong>{{ card.credible_success_path.two_week_validation_signal }}</strong></div>
            <div class="state-cell"><span class="metric-label"><span class="i18n-zh">终止信号</span><span class="i18n-en">kill signal</span></span><strong>{{ card.credible_success_path.kill_signal }}</strong></div>
