  </section>

  <section class="swiss-section decision-ledger" id="next-action" aria-labelledby="decision-prompt">
    <div class="section-heading">
      <div>
        <p class="eyebrow"><span class="i18n-zh">仅本地决策</span><span class="i18n-en">Local decision only</span></p>
        <h2 id="decision-prompt"><span class="i18n-zh">下一步怎么做</span><span class="i18n-en">Decision Prompt</span></h2>
      </div>
      <span class="pill pill-accent"><span class="i18n-zh">只选一个动作</span><span class="i18n-en">choose one action</span></span>
    </div>
    <p class="action-copy"><span class="i18n-zh">只需要决定是否启动首选项目：确定要做就执行 Start；还需要观察就 Snooze；明确不做就 Reject。其他候选项目先不进入本周执行。</span><span class="i18n-en">Decide only whether to start the recommended project: use Start if you will build it, Snooze if you need more signal, or Reject if this round is not worth doing.</span></p>
    <div class="command-stack">
      {% if report.decision_prompt.start_command %}
        <div class="command-row"><span class="command-label">start</span><div class="command" tabindex="0">{{ report.decision_prompt.start_command }}</div></div>
      {% endif %}
      {% if report.decision_prompt.snooze_command %}
        <div class="command-row"><span class="command-label">snooze</span><div class="command" tabindex="0">{{ report.decision_prompt.snooze_command }}</div></div>
      {% endif %}
      {% if report.decision_prompt.reject_command %}
        <div class="command-row"><span class="command-label">reject</span><div class="command" tabindex="0">{{ report.decision_prompt.reject_command }}</div></div>
      {% endif %}
    </div>
    <div class="decision-grid">
      <div class="swiss-panel alt">
        <h3><span class="i18n-zh">不应该做</span><span class="i18n-en">Should not do</span></h3>
        <ul>{% for item in report.decision_prompt.should_not_do %}<li>{{ item }}</li>{% else %}<li class="muted"><span class="i18n-zh">没有记录被阻止的方向。</span><span class="i18n-en">No blocked direction recorded.</span></li>{% endfor %}</ul>
      </div>
      <div class="swiss-panel">
        <h3><span class="i18n-zh">需要用户确认</span><span class="i18n-en">Needs user confirmation</span></h3>
        <ul>{% for item in report.decision_prompt.needs_user_confirmation %}<li>{{ item }}</li>{% else %}<li class="muted"><span class="i18n-zh">没有记录确认项。</span><span class="i18n-en">No confirmation item recorded.</span></li>{% endfor %}</ul>
      </div>
    </div>
  </section>
</main>
<script>
  const languageButtons = document.querySelectorAll("[data-language-button]");
  const applyLanguage = (language) => {
    const nextLanguage = language === "en" ? "en" : "zh";
    document.documentElement.dataset.language = nextLanguage;
    document.documentElement.lang = nextLanguage === "en" ? "en" : "zh-CN";
    languageButtons.forEach((button) => {
      button.setAttribute("aria-pressed", String(button.dataset.languageButton === nextLanguage));
    });
    try { localStorage.setItem("tradar.report.language", nextLanguage); } catch (_) {}
  };
  languageButtons.forEach((button) => {
    button.addEventListener("click", () => applyLanguage(button.dataset.languageButton));
  });
  let storedLanguage = "zh";
  try { storedLanguage = localStorage.getItem("tradar.report.language") || "zh"; } catch (_) {}
  applyLanguage(storedLanguage);
</script>
</body>
</html>
